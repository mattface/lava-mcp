# Copy to .env and edit for `docker compose up`.
#
# The server holds NO LAVA credentials: each connecting client sends its own
# LAVA target + token via X-Lava-Url / X-Lava-Token headers.

# Public domain for the MCP HTTPS endpoint (Caddy gets a cert for this).
# Agents connect to https://$LAVA_MCP_DOMAIN/mcp
LAVA_MCP_DOMAIN=lava-mcp.example.com

# Host/IP that lab worker containers can reach to dial the SSH board-session
# gateway (published on TCP :2222). Often the same machine's public/lab IP.
LAVA_MCP_GATEWAY_HOST=lava-mcp.example.com
