#!/bin/sh
# Open a reverse-SSH tunnel from this device-attached container to the lava-mcp
# gateway. Run by the ssh-gateway.yaml LAVA test definition; the GATEWAY_* /
# SESSION_* values come from the job's test parameters (exported as env vars).
set -eu

: "${GATEWAY_HOST:?missing GATEWAY_HOST}"
: "${GATEWAY_WS_URL:?missing GATEWAY_WS_URL}"
: "${SESSION_ID:?missing SESSION_ID}"
: "${REVERSE_PORT:?missing REVERSE_PORT}"
: "${SESSION_PRIVATE_KEY:?missing SESSION_PRIVATE_KEY}"
: "${SESSION_PUBLIC_KEY:?missing SESSION_PUBLIC_KEY}"

# The SSH stream tunnels over WebSocket/TLS (443, via Caddy) using websocat as an
# ssh ProxyCommand. Held in the positional params ($@, which this script otherwise
# ignores) so the ProxyCommand value — which contains a space — survives as a
# single ssh argument.
set -- -o "ProxyCommand=websocat -b ${GATEWAY_WS_URL}"
echo "lava-mcp: transport = websocket (${GATEWAY_WS_URL})"

mkdir -p /root/.ssh
chmod 700 /root/.ssh
# The gateway connects back into this container using the same session key.
printf '%s\n' "$SESSION_PUBLIC_KEY" >> /root/.ssh/authorized_keys
printf '%s\n' "$SESSION_PRIVATE_KEY" > /root/.ssh/session_key
chmod 600 /root/.ssh/authorized_keys /root/.ssh/session_key

# Start this container's sshd (key auth for root is permitted by default).
ssh-keygen -A >/dev/null
mkdir -p /run/sshd
/usr/sbin/sshd

echo "lava-mcp: dialing gateway as ${SESSION_ID}" \
     "(reverse ${REVERSE_PORT} -> localhost:22)"

# Keep the tunnel up for the life of the job. AUTOSSH_GATETIME=0 stops autossh from
# giving up when ssh exits quickly (e.g. gateway not ready yet / ExitOnForwardFailure),
# so it keeps reconnecting. A bounded outer loop retries a few times if autossh itself
# exits, then fails the job cleanly rather than hanging until the job timeout.
export AUTOSSH_GATETIME=0
attempt=0
max_attempts="${GATEWAY_CONNECT_ATTEMPTS:-10}"
while [ "$attempt" -lt "$max_attempts" ]; do
    attempt=$((attempt + 1))
    echo "lava-mcp: gateway connect attempt ${attempt}/${max_attempts}"
    autossh -M 0 -N \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        -o ServerAliveInterval=30 \
        -o ServerAliveCountMax=3 \
        -o ConnectTimeout=15 \
        -o ExitOnForwardFailure=yes \
        -i /root/.ssh/session_key \
        -R "127.0.0.1:${REVERSE_PORT}:localhost:22" \
        "$@" \
        "${SESSION_ID}@${GATEWAY_HOST}"
    echo "lava-mcp: gateway connection exited (attempt ${attempt}), retrying in 5s"
    sleep 5
done
echo "lava-mcp: giving up after ${max_attempts} gateway connect attempts" >&2
exit 1
